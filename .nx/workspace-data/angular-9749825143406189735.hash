      "projectType": "application",
      "sourceRoot": "apps/web/src",
      "targets": {
        "build": {
          "command": "ng build",
          "options": {
            "cwd": "."
          },
          "metadata": {
            "technologies": [
              "angular"
            ],
            "description": "Run the \"build\" target for \"web\".",
            "help": {
              "command": "npx ng run web:build --help",
              "example": {
                "options": {
                  "localize": true
                }
              }
            }
          },
          "dependsOn": [
            "^build"
          ],
          "outputs": [
            "{workspaceRoot}/dist/apps/web"
          ],
          "cache": true,
          "inputs": [
            "default",
            "^default",
            {
              "externalDependencies": [
                "@angular/cli"
              ]
            }
          ],
          "configurations": {
            "production": {
              "command": "ng run web:build:production"
            },
            "development": {
              "command": "ng run web:build:development"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "command": "ng serve",
          "options": {
            "cwd": "."
          },
          "metadata": {
            "technologies": [
              "angular"
            ],
            "description": "Run the \"serve\" target for \"web\".",
            "help": {
              "command": "npx ng run web:serve --help",
              "example": {
                "options": {
                  "port": 4201
                }
              }
            }
          },
          "configurations": {
            "production": {
              "command": "ng run web:serve:production"
            },
            "development": {
              "command": "ng run web:serve:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    },
